# 비밀키 템플릿 — 이 파일을 같은 폴더에 secrets.toml 이름으로 복사한 뒤 값을 채우세요.
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# secrets.toml은 .gitignore에 등록되어 있어 GitHub에 올라가지 않습니다.
# 모든 키는 선택 사항이며, 없어도 앱은 정상 동작합니다.

# OpenDART(한국 공시 원본) 키 — opendart.fss.or.kr 에서 무료 발급 후 따옴표 안에 붙여넣으세요.
OPENDART_API_KEY = ""

# Gemini(구글 AI) 키 — 뉴스 분석·AI 업종분류·종합 투자평가에 사용.
# aistudio.google.com 에서 무료 발급 후 아래 따옴표 안에 붙여넣으세요.
GEMINI_API_KEY = ""

# 모델명을 알면 고정 가능(예: "gemini-2.5-flash"). 비워두면 사용 가능한 flash를 자동 선택.
# GEMINI_MODEL = ""
