# 투자지표 환경변수 템플릿 — 이 파일을 복사해 `.env`로 만들고 실제 값을 채운다.
# `.env`(실제 키)는 커밋 금지(.gitignore에 포함). Render에서는 대시보드 Environment에 입력.

# 한국 공시 데이터(OpenDART) — https://opendart.fss.or.kr 에서 무료 발급
OPENDART_API_KEY=

# Gemini(AI 뉴스·투자평가) — 없어도 앱은 동작하며 AI 부분만 비활성화
GEMINI_API_KEY=

# 배포 시 외부 접속 허용에 필수(0.0.0.0). 로컬 개발은 비워두면 기본 127.0.0.1.
HOST=

# 서버 포트(Render 등 PaaS가 자동 주입). 로컬 기본 5178.
# PORT=5178
